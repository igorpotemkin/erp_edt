
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	СтруктураПараметров = ПолучитьИзВременногоХранилища(Параметры.Адрес);
	Элементы.ДекорацияОшибка.Заголовок = "";	
	
	Если ЗначениеЗаполнено(СтруктураПараметров.Пользователь) Тогда
		ЭтаФорма.Сотрудник = СтруктураПараметров.Пользователь; 
		ЭтотОбъект.ДокРО = Документы.РасходныйОрдерНаТовары.ПустаяСсылка(); 
		Объект.Склад = Справочники.Склады.НайтиПоНаименованию("ЦМ Цех Мюсли"); 
		УстановитьПараметрыФункциональныхОпцийФормы(Новый Структура("Склад,СХК_Этаж",Объект.Склад,Объект.СХК_Этаж));
		Объект.СХК_Этаж = Справочники.СкладскиеПомещения.НайтиПоНаименованию("Цех Мюсли 1 этаж"); 
		
		ТабРО.Параметры.УстановитьЗначениеПараметра("Автор",Справочники.Пользователи.НайтиПоНаименованию("Пенкина Марина Александровна").Ссылка);
		ТабРО.Параметры.УстановитьЗначениеПараметра("Дата",НачалоДня(ТекущаяДата())-2*86400);
		ТабРО.Параметры.УстановитьЗначениеПараметра("Получатель",Объект.Склад);
		ТабРО.Параметры.УстановитьЗначениеПараметра("Склад",Справочники.Склады.НайтиПоНаименованию("СМ Склад сырья и материалов"));
		ТабРО.Параметры.УстановитьЗначениеПараметра("Этаж",Объект.СХК_Этаж.Наименование);
		
	КонецЕсли;
	
КонецПроцедуры

