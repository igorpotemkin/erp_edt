&НаКлиенте
Процедура ОбработатьЗакрытиеФормыВыборПомещения(Значение, ДопПараметры) Экспорт
	Элементы.ДекорацияОшибка.Заголовок = "";	
	Если ЗначениеЗаполнено(Значение) Тогда 
		Если Не Значение.Этаж.Пустая() Тогда
			Объект.СХК_Этаж = Значение.Этаж;
			ЗаполнитьТаблицуТоваров();
			Если ТаблицаТоваров.Количество() >=1 Тогда 
				ГруппаТаблицаВидимость(Истина);
				ГруппаРОВидимость(Ложь);
				ГруппаформыВидимость(Ложь);
			КонецЕсли;
			
		Иначе
			Элементы.ДекорацияОшибка.Заголовок = "Повторите сканирование ордера"; 
			ГруппаТаблицаВидимость(Ложь)       ;
			ГруппаРОВидимость(Истина);
			ГруппаформыВидимость(Истина);
			АктивироватьПоиск();
		КонецЕсли;
	КонецЕсли;
	
	
КонецПроцедуры

&НаКлиенте
Процедура ВыборЭтажаНаКлиенте()
	
	ПараметрыФормыОстатки = Новый Структура;
	ПараметрыФормыОстатки.Вставить("ДокРО",ЭтаФорма.ДокРО );
	АдресПередаваемыхПараметров = ПоместитьВоВременноеХранилище(ПараметрыФормыОстатки,Новый УникальныйИдентификатор);
	_Параметры = новый Структура("Адрес", АдресПередаваемыхПараметров);
	ОписаниеОповещения = Новый ОписаниеОповещения("ОбработатьЗакрытиеФормыВыборПомещения", ЭтаФорма);
	ОткрытьФорму("Обработка.СХК_МобильныйСклад.Форма.СМ_ФормаПомещения", _Параметры,ЭтаФорма, , , , ОписаниеОповещения,РежимОткрытияОкнаФормы.БлокироватьВесьИнтерфейс);
	
КонецПроцедуры


&НаКлиенте
Процедура СканQRИзменениеТекстаРедактирования(Элемент, Текст, СтандартнаяОбработка)
	//ЗаполнитьТаблицуТоваров(Текст); 
	Если НайтиРО(Текст) = Истина Тогда
		ВыборЭтажаНаКлиенте();
	КонецЕсли;
КонецПроцедуры

&НаСервере
Функция НайтиРО(УИД)
	
	Элементы.ДекорацияОшибка.Заголовок = "";	
	ТаблицаТоваров.Очистить(); 
	
	Идентификатор = Новый УникальныйИдентификатор(УИД);
	ЭтотОбъект.ДокРО = Документы.РасходныйОрдерНаТовары.ПолучитьСсылку(Идентификатор);
	
	Если Не ДокРО.Пустая() И ДокРО.Проведен Тогда
		Если ДокРО.СХК_ПринятТСД = Истина Тогда
			ЭтотОбъект.ДокРО = Документы.РасходныйОрдерНаТовары.ПустаяСсылка();
			Элементы.ДекорацияОшибка.Заголовок = "Документ уже принят";	
		Иначе
			Возврат Истина;	
		КонецЕсли;
		
	Иначе
		ЭтотОбъект.ДокРО = Документы.РасходныйОрдерНаТовары.ПустаяСсылка();
		Элементы.ДекорацияОшибка.Заголовок = "Документ не найден";	
	КонецЕсли;
	
КонецФункции

